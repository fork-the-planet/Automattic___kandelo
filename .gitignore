# Claude
.claude/

# Build artifacts
/target
/sysroot/
/sysroot64/
/tools/bin/
host/dist/
host/docs/
host/wasm/

# Fetched / locally-built binaries. `binaries/` is populated by
# scripts/fetch-binaries.sh; `local-binaries/` is a user-managed
# override tree that takes priority. Neither is tracked.
/binaries/
/local-binaries/

# PR-build overlay file. Created by scripts/fetch-binaries.sh when
# checked out on a PR branch with a corresponding pr-<NNN>-staging
# pre-release. Never committed; see docs/binary-releases.md.
binaries.lock.pr

# Dependencies
node_modules/
/.direnv/

# Worktrees
.worktrees/

# Claude Code worktree config (added when an agent runs `claude` inside
# a worktree — never tracked).
.superset/

# Kandelo design handoff bundle (designer's reference prototype + spec).
# Lives at the repo root as input, not source — the production code is
# in apps/browser-demos/pages/kandelo/.
/design_handoff_kandelo_ui/

# musl build artifacts
/libc/musl/config.mak
/libc/musl/obj/
/libc/musl/lib/
/libc/musl/arch/wasm32posix/
/libc/musl/arch/wasm64posix/

# Wasm binaries are build artifacts. The kernel/userspace wasms live
# under binaries/ (fetched) or local-binaries/ (locally built); test
# fixtures under host/test/fixtures/ are produced by the vitest
# global-setup from .wat sources. Nothing tracked under git.
*.wasm

# VFS images are build artifacts produced by
# images/vfs/scripts/build-*-vfs-image.ts. Reproducible from
# source; not tracked.
*.vfs
*.vfs.zst
*.vfs.zst.meta.json

# OS noise
.DS_Store

# Editor/tool caches
.vite/
.playwright-mcp/
.build-cache/
docs-site/.vitepress/cache/
docs-site/.vitepress/dist/

# Browser example build output
apps/browser-demos/dist/

# Per-package source/build trees produced by packages/registry/*/build-*.sh.
# These are recreated on every build (clone or untar+make).
packages/registry/*/*-src/
packages/registry/*/*-host-build/
packages/registry/*/*-cross-build/
packages/registry/*/*-wasm-build/
packages/registry/*/*-build/
packages/registry/*/*-install/
packages/registry/*/*-dist/
packages/registry/*/*-fmt/
packages/registry/*/*-glue-objs*/
packages/registry/*/bin/

# VFS images produced by packages/registry/*-vfs/build-*-vfs.sh
packages/registry/*-vfs/*.vfs

# Per-package outliers
packages/registry/mariadb/pcre2-*/
packages/registry/msmtpd/msmtp-*.tar.xz
packages/registry/ncurses/terminfo/
packages/registry/nethack/runtime/
packages/registry/php/config.cache
packages/registry/redis/redis-*.tar.gz
packages/registry/texlive/install-tl/
packages/registry/texlive/texlive.profile
packages/registry/vim/runtime/
packages/registry/less/libtermcap/

# Built shared library + .wat-derived wasm fixtures (fixtures are
# regenerated by host/test/global-setup.ts on `vitest run`).
examples/dlopen/hello-lib.so

# nginx local source build artifacts
packages/registry/nginx/nginx-src/
packages/registry/nginx/nginx.wasm

# MariaDB data directory
packages/registry/mariadb/demo/data/

# WordPress download artifacts
packages/registry/wordpress/wordpress/
packages/registry/wordpress/sqlite-database-integration/

# libc-test build artifacts (source is a git submodule)
tests/libc/libc-test/build/

# Open POSIX Test Suite build artifacts
tests/posix/open-posix-testsuite/build/

# Debug/trace artifacts
examples/fp128*.c
examples/strtod_debug*.c
examples/div_trace.c
examples/mul_*.c
packages/registry/mariadb/test/test-data/

# Benchmark results and built wasm
benchmarks/results/
benchmarks/wasm/

# Phase C: per-package PR overlay (CI-generated; merged over package.toml at parse time).
packages/registry/*/package.pr.toml
