diff --git a/Library/Homebrew/kandelo_publisher.rb b/Library/Homebrew/kandelo_publisher.rb
new file mode 100644
index 0000000000..86f9dec415
--- /dev/null
+++ b/Library/Homebrew/kandelo_publisher.rb
@@ -0,0 +1,61 @@
+# typed: false
+# frozen_string_literal: true
+
+require "json"
+
+# Publisher-only validation for the root-owned dependency plan. This file is
+# added only to Kandelo's temporary Homebrew overlay.
+module KandeloPublisher
+  PLAN_FILENAME = ".kandelo-publisher-build-dependencies.json"
+  MAX_PLAN_BYTES = 65_536
+  PLAN_KEYS = %w[build build_and_test formula full_name runtime_and_test schema tap].freeze
+  DEPENDENCY_NAME = /\A[a-z0-9][a-z0-9@+_.-]*\z/
+
+  def self.active?
+    !dependency_plan(nil).nil?
+  end
+
+  def self.dependency_plan(formula = nil, require_match: true)
+    plan_path = HOMEBREW_PREFIX/PLAN_FILENAME
+    return unless plan_path.exist?
+
+    stat = plan_path.stat
+    prefix_stat = HOMEBREW_PREFIX.stat
+    protected_plan = plan_path.file? && !plan_path.symlink? && stat.uid == prefix_stat.uid &&
+                     (stat.mode & 0777) == 0444 && stat.nlink == 1 && stat.size <= MAX_PLAN_BYTES
+    raise "Kandelo publisher dependency plan is not a protected regular file" unless protected_plan
+
+    contents = plan_path.binread
+    if contents.bytesize > MAX_PLAN_BYTES
+      raise "Kandelo publisher dependency plan exceeds the size limit"
+    end
+
+    plan = JSON.parse(contents)
+    identified_plan = plan.is_a?(Hash) && plan.keys.sort == PLAN_KEYS && plan["schema"] == 2 &&
+                      plan["tap"].is_a?(String) && plan["formula"].is_a?(String) &&
+                      plan["full_name"] == "#{plan["tap"]}/#{plan["formula"]}"
+    raise "Kandelo publisher dependency plan has an invalid identity" unless identified_plan
+
+    arrays = %w[build build_and_test runtime_and_test].to_h do |key|
+      value = plan[key]
+      valid_names = value.is_a?(Array) && value == value.sort.uniq &&
+                    value.all? { |name| name.is_a?(String) && DEPENDENCY_NAME.match?(name) }
+      raise "Kandelo publisher dependency plan contains invalid #{key} names" unless valid_names
+
+      [key, value]
+    end
+    consistent_subsets = (arrays.fetch("build") - arrays.fetch("build_and_test")).empty? &&
+                         (arrays.fetch("runtime_and_test") - arrays.fetch("build_and_test")).empty?
+    raise "Kandelo publisher dependency plan subsets are inconsistent" unless consistent_subsets
+
+    return plan if formula.nil?
+
+    matches_formula = plan["formula"] == formula.name && plan["full_name"] == formula.full_name
+    return plan if matches_formula
+    return unless require_match
+
+    raise "Kandelo publisher dependency plan does not identify this Formula"
+  rescue JSON::ParserError => e
+    raise "Kandelo publisher dependency plan is invalid JSON: #{e.message}"
+  end
+end
