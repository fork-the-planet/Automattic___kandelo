#!/bin/bash
set -euo pipefail

SYSROOT="${WASM_POSIX_SYSROOT:-/usr/wasm32posix/sysroot}"
export PKG_CONFIG_LIBDIR="${SYSROOT}/lib/pkgconfig:${SYSROOT}/share/pkgconfig"

filtered_path=""
if [[ -n "${PKG_CONFIG_PATH:-}" ]]; then
  IFS=':' read -r -a parts <<<"${PKG_CONFIG_PATH}"
  for part in "${parts[@]}"; do
    [[ -n "$part" ]] || continue
    case "$part" in
      /usr/wasm32posix/*|*/kandelo/*|*/kandelo/*|*/sysroot/lib/pkgconfig|*/sysroot/share/pkgconfig)
        if [[ -n "$filtered_path" ]]; then
          filtered_path="${filtered_path}:${part}"
        else
          filtered_path="$part"
        fi
        ;;
    esac
  done
fi
export PKG_CONFIG_PATH="$filtered_path"

exec pkg-config "$@"
