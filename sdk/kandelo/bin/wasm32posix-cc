#!/bin/bash
set -euo pipefail

SDK_CXX="${WASM_POSIX_CXX_DRIVER:-0}"
if [[ "$(basename "$0")" == *c++ ]]; then
  SDK_CXX=1
fi

die() {
  echo "wasm32posix-cc: $*" >&2
  exit 1
}

find_tool() {
  local name="$1"
  if [[ -n "${WASM_POSIX_LLVM_DIR:-}" && -x "${WASM_POSIX_LLVM_DIR}/${name}" ]]; then
    printf '%s\n' "${WASM_POSIX_LLVM_DIR}/${name}"
    return 0
  fi
  local dir
  for dir in /usr/lib/llvm/bin /usr/local/bin /usr/bin /bin; do
    if [[ -x "${dir}/${name}" ]]; then
      printf '%s\n' "${dir}/${name}"
      return 0
    fi
  done
  if command -v "$name" >/dev/null 2>&1; then
    command -v "$name"
    return 0
  fi
  return 1
}

if [[ "$SDK_CXX" -eq 1 ]]; then
  CLANG="$(find_tool clang++ || true)"
  [[ -n "$CLANG" ]] || die "clang++ not found; set WASM_POSIX_LLVM_DIR"
else
  CLANG="$(find_tool clang || true)"
  [[ -n "$CLANG" ]] || die "clang not found; set WASM_POSIX_LLVM_DIR"
fi

TOOL_DIR="$(dirname "$CLANG")"
SYSROOT="${WASM_POSIX_SYSROOT:-/usr/wasm32posix/sysroot}"
GLUE_DIR="${WASM_POSIX_GLUE_DIR:-/usr/wasm32posix/glue}"
GLUE_OBJ_DIR="${WASM_POSIX_GLUE_OBJ_DIR:-/usr/wasm32posix/glue-objects}"
RESOURCE_DIR="${WASM_POSIX_CLANG_RESOURCE_DIR:-/usr/lib/llvm/lib/clang/21}"
WASM_LD="${TOOL_DIR}/wasm-ld"

[[ -f "${SYSROOT}/lib/libc.a" ]] || die "missing ${SYSROOT}/lib/libc.a"
[[ -f "${GLUE_DIR}/channel_syscall.c" ]] || die "missing ${GLUE_DIR}/channel_syscall.c"
[[ -x "$WASM_LD" ]] || die "matching wasm-ld not found beside $CLANG; set WASM_POSIX_LLVM_DIR to a complete LLVM toolchain"

linking=1
shared=0
link_dl=0
thread_slots_decl=""
raw_threads_or_dynamic=0
filtered=()

parse_thread_slots_decl() {
  local value="$1"
  [[ "$value" =~ ^-?[0-9]+$ ]] || die "--kandelo-thread-slots must be -1, 0, or a positive integer"
  if (( value < -1 )); then
    die "--kandelo-thread-slots must be -1, 0, or a positive integer"
  fi
  printf '%s\n' "$value"
}

while [[ "$#" -gt 0 ]]; do
  arg="$1"
  shift
  case "$arg" in
    -c|-E|-S)
      linking=0
      filtered+=("$arg")
      ;;
    -shared)
      shared=1
      raw_threads_or_dynamic=1
      ;;
    -ldl)
      link_dl=1
      raw_threads_or_dynamic=1
      ;;
    --kandelo-thread-slots|--wasm-posix-thread-slots)
      [[ "$#" -gt 0 ]] || die "$arg requires -1, 0, or a positive integer"
      thread_slots_decl="$(parse_thread_slots_decl "$1")"
      shift
      ;;
    --kandelo-thread-slots=*|--wasm-posix-thread-slots=*)
      thread_slots_decl="$(parse_thread_slots_decl "${arg#*=}")"
      ;;
    -pthread|-lpthread|-rdynamic)
      raw_threads_or_dynamic=1
      ;;
    -fPIE|-pie|-lrt|-lresolv|-lm|-lcrypt|-lutil|-Wl,-Bsymbolic)
      ;;
    -Wl,-rpath,*|-Wl,-soname,*|-Wl,--version-script*)
      raw_threads_or_dynamic=1
      ;;
    -dynamiclib)
      raw_threads_or_dynamic=1
      echo "wasm32posix-cc: warning: ${arg} is not supported for Wasm targets (ignored)" >&2
      ;;
    *)
      filtered+=("$arg")
      ;;
  esac
done

compile_flags=(
  --target=wasm32-unknown-unknown
  -matomics
  -mbulk-memory
  -mexception-handling
  -mllvm -wasm-enable-sjlj
  -mllvm -wasm-use-legacy-eh=false
  -fno-trapping-math
  -fintegrated-cc1
  -ccc-install-dir "$TOOL_DIR"
  "-B${TOOL_DIR}"
  "--sysroot=${SYSROOT}"
)

if [[ -d "$RESOURCE_DIR" ]]; then
  compile_flags+=(-resource-dir "$RESOURCE_DIR")
fi

shared_link_flags=(
  -nostdlib
  -Wl,--experimental-pic
  -Wl,--shared
  -Wl,--shared-memory
  -Wl,--export-all
  -Wl,--allow-undefined
)

exe_link_flags=(
  -nostdlib
  -Wl,--entry=_start
  -Wl,--export=_start
  -Wl,--export=__heap_base
  -Wl,--import-memory
  -Wl,--shared-memory
  -Wl,--max-memory=1073741824
  -Wl,--allow-undefined
  -Wl,--global-base=1114112
  -Wl,--table-base=3
  -Wl,--export-table
  -Wl,--growable-table
  -Wl,--export=__wasm_init_tls
  -Wl,--export=__tls_base
  -Wl,--export=__tls_size
  -Wl,--export=__tls_align
  -Wl,--export=__stack_pointer
  -Wl,--export=__wasm_thread_init
  -Wl,--export=__abi_version
)

if [[ "$linking" -eq 0 ]]; then
  exec "$CLANG" "${compile_flags[@]}" "${filtered[@]}"
fi

output="a.out"
compile_args=()
source_inputs=()
object_inputs=()
user_link_args=()

idx=0
while [[ "$idx" -lt "${#filtered[@]}" ]]; do
  arg="${filtered[$idx]}"
  case "$arg" in
    -o)
      idx=$((idx + 1))
      [[ "$idx" -lt "${#filtered[@]}" ]] || die "-o requires an output path"
      output="${filtered[$idx]}"
      ;;
    -o*)
      output="${arg#-o}"
      ;;
    *.c|*.cc|*.cpp|*.cxx|*.C)
      source_inputs+=("$arg")
      ;;
    *.o|*.obj|*.a)
      object_inputs+=("$arg")
      ;;
    -Wl,*)
      IFS=',' read -r -a wl_parts <<< "${arg#-Wl,}"
      user_link_args+=("${wl_parts[@]}")
      ;;
    -L)
      idx=$((idx + 1))
      [[ "$idx" -lt "${#filtered[@]}" ]] || die "-L requires a directory"
      user_link_args+=("-L${filtered[$idx]}")
      ;;
    -L*|-l*)
      user_link_args+=("$arg")
      ;;
    *)
      compile_args+=("$arg")
      ;;
  esac
  idx=$((idx + 1))
done

compiled_objects=()
for src in "${source_inputs[@]}"; do
  base="$(basename "$src")"
  obj="/tmp/${base}.$$.$((${#compiled_objects[@]} + 1)).o"
  "$CLANG" "${compile_flags[@]}" "${compile_args[@]}" -c "$src" -o "$obj"
  compiled_objects+=("$obj")
done

infer_thread_slots_decl() {
  if [[ -n "$thread_slots_decl" ]]; then
    printf '%s\n' "$thread_slots_decl"
    return
  fi
  if [[ "$shared" -eq 1 || "$link_dl" -eq 1 || "$raw_threads_or_dynamic" -eq 1 ]]; then
    printf '%s\n' "-1"
    return
  fi
  if [[ "${#object_inputs[@]}" -gt 0 || "${#source_inputs[@]}" -eq 0 ]]; then
    printf '%s\n' "-1"
    return
  fi
  local arg src
  for arg in "${user_link_args[@]}"; do
    case "$arg" in
      -l*|-Wl,*|@*) printf '%s\n' "-1"; return ;;
    esac
  done
  for src in "${source_inputs[@]}"; do
    if grep -Eq 'pthread_create|thrd_create|clone[[:space:]]*\(|std::thread|#include[[:space:]]*<thread>|dlopen|__wasm_dlopen' "$src" 2>/dev/null; then
      printf '%s\n' "-1"
      return
    fi
  done
  printf '%s\n' "0"
}

append_ld_flags() {
  local flag part
  for flag in "$@"; do
    case "$flag" in
      -nostdlib)
        ;;
      -Wl,*)
        IFS=',' read -r -a wl_parts <<< "${flag#-Wl,}"
        for part in "${wl_parts[@]}"; do
          ld_flags+=("$part")
        done
        ;;
      *)
        ld_flags+=("$flag")
        ;;
    esac
  done
}

ld_flags=()
if [[ "$shared" -eq 1 ]]; then
  append_ld_flags "${shared_link_flags[@]}"
  "$WASM_LD" -m wasm32 -L"${SYSROOT}/lib" \
    "${object_inputs[@]}" "${compiled_objects[@]}" "${user_link_args[@]}" \
    "${ld_flags[@]}" -o "$output"
  exit $?
fi

glue_inputs=(
  "${GLUE_OBJ_DIR}/compiler_rt.o"
  "${GLUE_OBJ_DIR}/cxxrt.o"
)
channel_syscall_obj="${GLUE_OBJ_DIR}/channel_syscall.o"
thread_slots_final="$(infer_thread_slots_decl)"
if [[ "$thread_slots_final" != "-1" ]]; then
  channel_syscall_obj="/tmp/channel_syscall.$$.$thread_slots_final.o"
  "$CLANG" "${compile_flags[@]}" "-DWASM_POSIX_THREAD_SLOT_DECL=${thread_slots_final}" \
    -c "$GLUE_DIR/channel_syscall.c" -o "$channel_syscall_obj"
fi
glue_inputs=("$channel_syscall_obj" "${glue_inputs[@]}")
if [[ "$link_dl" -eq 1 ]]; then
  glue_inputs+=("${GLUE_OBJ_DIR}/dlopen.o")
fi
if [[ ! -f "${glue_inputs[0]}" ]]; then
  die "missing precompiled glue objects in ${GLUE_OBJ_DIR}"
fi

stdlib_inputs=()
if [[ "$SDK_CXX" -eq 1 ]]; then
  [[ -f "${SYSROOT}/lib/libc++.a" ]] || die "missing ${SYSROOT}/lib/libc++.a"
  [[ -f "${SYSROOT}/lib/libc++abi.a" ]] || die "missing ${SYSROOT}/lib/libc++abi.a"
  stdlib_inputs+=("${SYSROOT}/lib/libc++.a" "${SYSROOT}/lib/libc++abi.a")
fi

lld_major="$("$WASM_LD" --version | sed -nE 's/.*LLD ([0-9]+).*/\1/p' | head -1)"
[[ "$lld_major" =~ ^[0-9]+$ ]] || die "could not determine wasm-ld version"
if (( lld_major >= 22 )); then
  # LLD 22 changed its default to --stack-first. Preserve the established
  # stack-after-data layout; LLD 21 does not accept this negative option.
  exe_link_flags+=(-Wl,--no-stack-first)
fi
append_ld_flags "${exe_link_flags[@]}"
"$WASM_LD" -m wasm32 -L"${SYSROOT}/lib" \
  "${object_inputs[@]}" "${compiled_objects[@]}" "${glue_inputs[@]}" \
  "${SYSROOT}/lib/crt1.o" "${user_link_args[@]}" "${stdlib_inputs[@]}" "${SYSROOT}/lib/libc.a" \
  "${ld_flags[@]}" -o "$output"
exit $?
