--- a/js/src/shell/js.cpp
+++ b/js/src/shell/js.cpp
@@ -5019,6 +5019,42 @@ static void KillWorkerThreads(JSContext* cx) {
   workerThreadsLock = nullptr;
 }
 
+static void JoinShellWorkerThreadsForKandelo() {
+  MOZ_ASSERT_IF(!CanUseExtraThreads(), workerThreads.empty());
+
+  if (!workerThreadsLock) {
+    MOZ_ASSERT(workerThreads.empty());
+    return;
+  }
+
+  while (true) {
+    UniquePtr<Thread> thread;
+    {
+      AutoLockWorkerThreads alwt;
+      if (workerThreads.empty()) {
+        break;
+      }
+      thread = std::move(workerThreads.back());
+      workerThreads.popBack();
+    }
+    thread->join();
+  }
+
+  workerThreads.clearAndFree();
+}
+
+static bool JoinWorkerThreads(JSContext* cx, unsigned argc, Value* vp) {
+  CallArgs args = CallArgsFromVp(argc, vp);
+  if (args.length() != 0) {
+    JS_ReportErrorASCII(cx, "joinWorkerThreads takes no arguments");
+    return false;
+  }
+
+  JoinShellWorkerThreadsForKandelo();
+  args.rval().setUndefined();
+  return true;
+}
