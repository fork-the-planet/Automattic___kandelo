{
  "name": "wasm-posix-host",
  "version": "0.1.0",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "require": {
        "types": "./dist/browser.d.cts",
        "default": "./dist/browser.cjs"
      }
    },
    "./vfs": {
      "import": {
        "types": "./dist/vfs/index.d.ts",
        "default": "./dist/vfs/index.js"
      },
      "require": {
        "types": "./dist/vfs/index.d.cts",
        "default": "./dist/vfs/index.cjs"
      }
    },
    "./networking": {
      "import": {
        "types": "./dist/networking/index.d.ts",
        "default": "./dist/networking/index.js"
      },
      "require": {
        "types": "./dist/networking/index.d.cts",
        "default": "./dist/networking/index.cjs"
      }
    },
    "./framebuffer": {
      "import": {
        "types": "./dist/framebuffer/index.d.ts",
        "default": "./dist/framebuffer/index.js"
      },
      "require": {
        "types": "./dist/framebuffer/index.d.cts",
        "default": "./dist/framebuffer/index.cjs"
      }
    },
    "./worker-entry": {
      "browser": {
        "types": "./dist/worker-entry-browser.d.ts",
        "default": "./dist/worker-entry-browser.js"
      },
      "import": {
        "types": "./dist/worker-entry.d.ts",
        "default": "./dist/worker-entry.js"
      },
      "require": {
        "types": "./dist/worker-entry.d.cts",
        "default": "./dist/worker-entry.cjs"
      }
    },
    "./worker-entry-browser": {
      "import": {
        "types": "./dist/worker-entry-browser.d.ts",
        "default": "./dist/worker-entry-browser.js"
      }
    },
    "./node-kernel-worker-entry": {
      "import": {
        "types": "./dist/node-kernel-worker-entry.d.ts",
        "default": "./dist/node-kernel-worker-entry.js"
      },
      "require": {
        "types": "./dist/node-kernel-worker-entry.d.cts",
        "default": "./dist/node-kernel-worker-entry.cjs"
      }
    },
    "./vfs/opfs-worker": {
      "import": {
        "types": "./dist/vfs/opfs-worker.d.ts",
        "default": "./dist/vfs/opfs-worker.js"
      }
    },
    "./wasm": "./wasm/kandelo-kernel.wasm",
    "./kernel.wasm": "./wasm/kandelo-kernel.wasm",
    "./rootfs.vfs": "./wasm/rootfs.vfs",
    "./wasm/*": "./wasm/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsup --dts-only",
    "docs": "typedoc",
    "test": "vitest",
    "test:teardown": "vitest run test/teardown-reclaim.test.ts test/pthread.test.ts",
    "test:teardown:bun": "bun x vitest run test/teardown-reclaim.test.ts test/pthread.test.ts",
    "test:teardown:engines": "npm run test:teardown && npm run test:teardown:bun",
    "prepack": "npm run build && bash ../scripts/prepare-host-package.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1"
  }
}
